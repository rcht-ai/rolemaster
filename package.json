{
  "name": "rolemaster",
  "private": true,
  "version": "0.1.0",
  "description": "AI capability delivery platform on Cloudflare Pages + Functions + D1 + R2.",
  "scripts": {
    "install:all": "npm install && npm install --prefix app",
    "build": "npm run build --prefix app",
    "dev": "concurrently -n web,api -c blue,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm run dev --prefix app",
    "dev:api": "wrangler pages dev dist --port 8788 --d1 DB --r2 R2",
    "schema": "wrangler d1 execute rolemaster-db --file=schema.sql --remote",
    "seed": "wrangler d1 execute rolemaster-db --file=seed.sql --remote",
    "schema:local": "wrangler d1 execute rolemaster-db --file=schema.sql --local",
    "seed:local": "wrangler d1 execute rolemaster-db --file=seed.sql --local",
    "deploy:uat": "node scripts/deploy.mjs uat",
    "deploy:prod": "node scripts/deploy.mjs prod"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "wrangler": "^3.91.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "pdf-lib": "^1.17.1",
    "pptxgenjs": "^3.12.0"
  },
  "engines": {
    "node": ">=20"
  }
}
